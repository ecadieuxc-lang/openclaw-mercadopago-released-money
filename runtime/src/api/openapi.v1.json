            }
          }
        },
        "parameters": [
          {
            "name": "period_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "2026-06"
          }
        ]
      }
    },
    "/v1/finance/history": {
      "get": {
