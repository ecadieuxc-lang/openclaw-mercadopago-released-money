{
  "openapi": "3.1.0",
  "info": {
    "title": "openclaw-mercadopago-released-money API",
    "version": "1.0.0",
    "description": "Local API contract for Mercado Pago Released Money clean processed data."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3766",
      "description": "Default local-only API server"
    }
  ],
  "security": [
    {
      "financeBearerAuth": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Public healthcheck for the future local process",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/v1/system/doctor": {
      "get": {
        "summary": "Safe diagnostic status",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DoctorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
