    },
    "/v1/finance/clarifications/{id}/answer": {
      "post": {
        "summary": "Answer clarification",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Clarification"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "clar_sample_001"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "answer"
                ],
                "properties": {
                  "answer": {
                    "type": "string",
                    "example": "Transferencia personal confirmada por operador sintético."
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/finance/coach/current": {
      "get": {
        "summary": "Current coach report",
        "responses": {
